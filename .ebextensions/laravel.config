option_settings:
  # ── PHP Runtime Config ───────────────────────────────────────────────────
  aws:elasticbeanstalk:container:php:phpini:
    document_root: /public
    memory_limit: 256M
    max_execution_time: 300
    display_errors: "Off"
    composer_options: "--no-dev --optimize-autoloader"

  # ── Environment Variables ─────────────────────────────────────────────────
  aws:elasticbeanstalk:application:environment:
    APP_ENV: production
    APP_DEBUG: false
    LOG_CHANNEL: stderr

container_commands:
  # ── 01: Jalankan migrasi database ────────────────────────────────────────
  01_migrate:
    command: "php artisan migrate --force"
    leader_only: true

  # ── 02: Buat symlink storage → public ────────────────────────────────────
  02_storage_link:
    command: "php artisan storage:link"
    leader_only: true

  # ── 03: Upgrade Filament assets ───────────────────────────────────────────
  #         Wajib setiap kali deploy agar panel Admin/Guru/Siswa tidak blank
  03_filament_upgrade:
    command: "php artisan filament:upgrade"
    leader_only: true

  # ── 04: Optimize config, route, view cache ────────────────────────────────
  04_optimize:
    command: "php artisan optimize"
    leader_only: true

  # ── 05: Restart queue workers ─────────────────────────────────────────────
  05_queue_restart:
    command: "php artisan queue:restart"
    leader_only: true

  # ── 98: Jadikan postdeploy script executable ───────────────────────────────
  98_make_postdeploy_executable:
    command: "chmod +x .platform/hooks/postdeploy/01_set_permissions.sh"
    ignoreErrors: true

  # ── 99: Set permission folder storage & bootstrap (HARUS TERAKHIR) ───────
  99_storage_permission:
    command: "chmod -R 775 storage bootstrap/cache && chown -R webapp:webapp storage bootstrap/cache"
    leader_only: true
